7:["$","$L10",null,{"data":{"hero":{"title":"把经营数据变成可跟进的趋势、预测和预警。","description":"从经营数据上传到趋势分析、预测和预警提醒，都在同一个驾驶舱里完成，便于团队快速跟进异常。"},"rangeOptions":[{"id":"7d","label":"近 7 天","description":"适合观察短周期波动和执行后反馈。"},{"id":"30d","label":"近 30 天","description":"适合看月度经营节奏和回款变化。"},{"id":"90d","label":"近 90 天","description":"适合看季度趋势和预算偏差。"},{"id":"12m","label":"近 12 个月","description":"适合看年度趋势和现金流预测。"}],"defaultRange":"30d","uploads":[{"id":"insight-upload-1","name":"2026-Q1-经营数据.xlsx","size":"1.8 MB","updatedAt":"2026-03-15 09:34","status":"parsed"},{"id":"insight-upload-2","name":"回款计划-周度.csv","size":"284 KB","updatedAt":"2026-03-15 09:41","status":"parsed"},{"id":"insight-upload-3","name":"销售预测补录表.xlsx","size":"522 KB","updatedAt":"2026-03-15 09:46","status":"uploading"}],"stateSnapshots":{"default":{"title":"等待分析","summary":"当前已上传数据源并配置展示范围，尚未生成经营分析结果。","status":"draft","notice":"默认状态适合展示首次进入驾驶舱或等待用户选择时间范围的场景。","noticeTone":"neutral","actionLabel":"开始分析","datasets":{"7d":{"metrics":[],"trendSeries":[],"forecastSeries":[],"summary":"当前没有图表数据。"},"30d":{"metrics":[],"trendSeries":[],"forecastSeries":[],"summary":"当前没有图表数据。"},"90d":{"metrics":[],"trendSeries":[],"forecastSeries":[],"summary":"当前没有图表数据。"},"12m":{"metrics":[],"trendSeries":[],"forecastSeries":[],"summary":"当前没有图表数据。"}},"alerts":[],"recommendations":[{"id":"ins-default-1","title":"先确认指标口径","detail":"建议先统一收入确认、成本归集和现金流统计口径，再开始做趋势预测。"}]},"loading":{"title":"分析中","summary":"正在聚合经营数据、生成趋势图并计算预警规则。","status":"running","notice":"系统正在对账期、回款和现金流做聚合计算，完成后会同步生成预警。","noticeTone":"warning","actionLabel":"分析中...","datasets":{"7d":{"metrics":[],"trendSeries":[],"forecastSeries":[],"summary":"正在计算近 7 天数据。"},"30d":{"metrics":[],"trendSeries":[],"forecastSeries":[],"summary":"正在计算近 30 天数据。"},"90d":{"metrics":[],"trendSeries":[],"forecastSeries":[],"summary":"正在计算近 90 天数据。"},"12m":{"metrics":[],"trendSeries":[],"forecastSeries":[],"summary":"正在计算近 12 个月数据。"}},"alerts":[],"recommendations":[{"id":"ins-loading-1","title":"等待模型结果","detail":"趋势与预测完成后，将联动生成经营建议和风险预警。"}]},"success":{"title":"分析完成","summary":"已生成收入、成本、现金流趋势图，并识别 3 条经营预警。","status":"completed","notice":"建议下一步把高优先级预警推送到任务中心，形成从数据洞察到执行动作的闭环。","noticeTone":"success","actionLabel":"创建预警任务","datasets":{"7d":{"metrics":[{"id":"rev-7d","label":"收入","value":"¥48.6k","delta":"+8.2%","direction":"up","description":"近 7 天累计确认收入"},{"id":"cost-7d","label":"成本","value":"¥26.8k","delta":"+3.4%","direction":"up","description":"近 7 天累计成本"},{"id":"cash-7d","label":"现金流","value":"¥14.9k","delta":"+11.1%","direction":"up","description":"近 7 天经营现金流净额"},{"id":"warn-7d","label":"预警数","value":"01","delta":"-1","direction":"down","description":"近 7 天高优先级预警"}],"trendSeries":[{"label":"周一","revenue":5.2,"cost":3.6,"cashflow":1.2},{"label":"周二","revenue":6.4,"cost":3.8,"cashflow":1.8},{"label":"周三","revenue":7.1,"cost":4.1,"cashflow":2.2},{"label":"周四","revenue":6.8,"cost":4.2,"cashflow":1.7},{"label":"周五","revenue":8.3,"cost":4.9,"cashflow":2.4},{"label":"周六","revenue":7.2,"cost":3.5,"cashflow":2.7},{"label":"周日","revenue":7.6,"cost":2.7,"cashflow":2.9}],"forecastSeries":[{"label":"本周","actual":14.9,"forecast":15.3},{"label":"下周","actual":0,"forecast":16.1},{"label":"两周后","actual":0,"forecast":16.8}],"summary":"近 7 天现金流保持为正，收入增长快于成本。"},"30d":{"metrics":[{"id":"rev-30d","label":"收入","value":"¥226k","delta":"+12.4%","direction":"up","description":"近 30 天累计确认收入"},{"id":"cost-30d","label":"成本","value":"¥148k","delta":"+6.7%","direction":"up","description":"近 30 天累计成本"},{"id":"cash-30d","label":"现金流","value":"¥54k","delta":"+9.1%","direction":"up","description":"近 30 天经营现金流净额"},{"id":"warn-30d","label":"预警数","value":"03","delta":"+1","direction":"up","description":"近 30 天待跟进预警"}],"trendSeries":[{"label":"W1","revenue":46,"cost":32,"cashflow":9},{"label":"W2","revenue":52,"cost":34,"cashflow":11},{"label":"W3","revenue":57,"cost":38,"cashflow":14},{"label":"W4","revenue":71,"cost":44,"cashflow":20}],"forecastSeries":[{"label":"本月","actual":54,"forecast":56},{"label":"下月","actual":0,"forecast":58},{"label":"次月","actual":0,"forecast":61}],"summary":"近 30 天收入增速稳定，第四周回款改善带动现金流抬升。"},"90d":{"metrics":[{"id":"rev-90d","label":"收入","value":"¥648k","delta":"+15.1%","direction":"up","description":"近 90 天累计确认收入"},{"id":"cost-90d","label":"成本","value":"¥433k","delta":"+10.6%","direction":"up","description":"近 90 天累计成本"},{"id":"cash-90d","label":"现金流","value":"¥128k","delta":"+7.8%","direction":"up","description":"近 90 天经营现金流净额"},{"id":"warn-90d","label":"预警数","value":"04","delta":"+1","direction":"up","description":"季度内触发的重点预警"}],"trendSeries":[{"label":"1月","revenue":186,"cost":129,"cashflow":31},{"label":"2月","revenue":201,"cost":138,"cashflow":38},{"label":"3月","revenue":261,"cost":166,"cashflow":59}],"forecastSeries":[{"label":"Q1","actual":128,"forecast":128},{"label":"Q2","actual":0,"forecast":136},{"label":"Q3","actual":0,"forecast":144}],"summary":"季度收入持续增长，但成本也同步抬升，需要关注营销投入回收期。"},"12m":{"metrics":[{"id":"rev-12m","label":"收入","value":"¥2.84M","delta":"+18.2%","direction":"up","description":"近 12 个月累计确认收入"},{"id":"cost-12m","label":"成本","value":"¥1.93M","delta":"+11.3%","direction":"up","description":"近 12 个月累计成本"},{"id":"cash-12m","label":"现金流","value":"¥572k","delta":"+6.9%","direction":"up","description":"近 12 个月经营现金流净额"},{"id":"warn-12m","label":"预警数","value":"05","delta":"+2","direction":"up","description":"年度内累计触发预警"}],"trendSeries":[{"label":"4月","revenue":192,"cost":138,"cashflow":32},{"label":"5月","revenue":201,"cost":142,"cashflow":37},{"label":"6月","revenue":216,"cost":149,"cashflow":42},{"label":"7月","revenue":224,"cost":156,"cashflow":44},{"label":"8月","revenue":231,"cost":161,"cashflow":46},{"label":"9月","revenue":227,"cost":158,"cashflow":41},{"label":"10月","revenue":236,"cost":162,"cashflow":48},{"label":"11月","revenue":241,"cost":165,"cashflow":51},{"label":"12月","revenue":248,"cost":171,"cashflow":56},{"label":"1月","revenue":252,"cost":174,"cashflow":58},{"label":"2月","revenue":261,"cost":180,"cashflow":55},{"label":"3月","revenue":311,"cost":207,"cashflow":62}],"forecastSeries":[{"label":"本季","actual":172,"forecast":172},{"label":"下季","actual":0,"forecast":181},{"label":"两季后","actual":0,"forecast":194}],"summary":"年度收入上行明显，但成本曲线同步提升，现金流改善幅度略慢于收入增幅。"}},"alerts":[{"id":"alert-1","level":"high","title":"回款周期拉长","summary":"近两周平均回款周期较上月延长 5.2 天，影响短期现金流。","action":"建议发起回款跟进任务并核查账期异常客户。"},{"id":"alert-2","level":"medium","title":"营销投入回收偏慢","summary":"最近一轮投放成本提升 12%，但新增订单转化未同步增长。","action":"建议检查渠道质量，压缩低转化投放预算。"},{"id":"alert-3","level":"medium","title":"人力成本上升","summary":"本月固定人力成本较季度均值提升，已接近预算阈值。","action":"建议评估项目优先级，延后非核心招聘计划。"}],"recommendations":[{"id":"rec-1","title":"优先处理回款异常客户","detail":"现金流改善最直接的动作不是压缩所有成本，而是先缩短异常账期客户的回款周期。"},{"id":"rec-2","title":"把预算预警接入任务中心","detail":"建议将高风险告警自动生成任务，交给运营或财务负责人跟进并闭环记录。"},{"id":"rec-3","title":"分离固定与弹性成本观察","detail":"当前成本上升来自多个来源，建议在下一版图表中拆开固定成本和投放成本。"}]},"empty":{"title":"没有可展示的数据","summary":"当前筛选范围或上传结果不足，未生成有效图表。","status":"completed","notice":"空状态适合演示首次接入数据源或当前筛选没有命中结果时的反馈。","noticeTone":"neutral","actionLabel":"重新上传数据","datasets":{"7d":{"metrics":[],"trendSeries":[],"forecastSeries":[],"summary":"无数据。"},"30d":{"metrics":[],"trendSeries":[],"forecastSeries":[],"summary":"无数据。"},"90d":{"metrics":[],"trendSeries":[],"forecastSeries":[],"summary":"无数据。"},"12m":{"metrics":[],"trendSeries":[],"forecastSeries":[],"summary":"无数据。"}},"alerts":[],"recommendations":[{"id":"rec-empty-1","title":"确认数据源完整性","detail":"建议检查时间字段、金额字段和去重逻辑后重新上传。"}]},"error":{"title":"分析失败","summary":"模拟聚合层异常，页面保留已上传数据源和时间范围设置。","status":"failed","notice":"FastAPI 聚合层返回超时。建议记录 traceId 并提供重试与降级展示模式。","noticeTone":"danger","actionLabel":"重试分析","datasets":{"7d":{"metrics":[],"trendSeries":[],"forecastSeries":[],"summary":"结果不可用。"},"30d":{"metrics":[],"trendSeries":[],"forecastSeries":[],"summary":"结果不可用。"},"90d":{"metrics":[],"trendSeries":[],"forecastSeries":[],"summary":"结果不可用。"},"12m":{"metrics":[],"trendSeries":[],"forecastSeries":[],"summary":"结果不可用。"}},"alerts":[{"id":"alert-error-1","level":"high","title":"当前结果不可用","summary":"由于分析链异常，本次预警与预测结果不能作为决策依据。","action":"建议重试分析，并查看日志确认数据源映射是否异常。"}],"recommendations":[{"id":"rec-error-1","title":"保留上次成功快照","detail":"后续可在真实接口中支持读取上一次成功分析结果，避免驾驶舱完全空白。"}]}},"integrationPoints":["POST /api/insights/upload","GET /api/insights/overview","GET /api/insights/alerts","POST /api/insights/export"]}}]
