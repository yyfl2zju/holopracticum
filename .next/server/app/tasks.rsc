7:["$","$L10",null,{"data":{"hero":{"title":"把一句业务诉求转成一条可执行任务链。","description":"任务中心统一接收自然语言、附件和业务上下文，先识别任务类型，再分发给对应的执行链路。"},"draftInput":"帮我审查这份劳动合同，标出高风险条款，并生成一份适合创业公司签约的修改建议版本。","promptPresets":["帮我审查这份劳动合同","根据这个需求生成 FastAPI 接口代码和测试建议","写一篇适合公众号和小红书双平台发布的产品介绍文案","分析这份财务表并预测未来三个月现金流"],"acceptedFileTypes":["PDF","DOCX","XLSX","CSV","PNG"],"uploads":[{"id":"contract-file-001","name":"劳动合同-签署版-v7.pdf","size":"2.1 MB","kind":"contract","status":"parsed"},{"id":"contract-file-002","name":"员工手册-试用期政策.docx","size":"612 KB","kind":"requirements","status":"parsed"},{"id":"run-file-004","name":"历史争议条款整理.xlsx","size":"312 KB","kind":"spreadsheet","status":"parsed"}],"recognizedSignals":[{"id":"signal-contract","label":"合同风险审查","type":"contract","confidence":0.96,"reason":"识别到“劳动合同”“高风险条款”“修改建议”等法务语义。","priority":"high"},{"id":"signal-doc-gen","label":"模板文书生成","type":"contract","confidence":0.88,"reason":"用户明确要求生成可签约版本，适合进入文书模板填充链路。","priority":"medium"},{"id":"signal-human-review","label":"需要人工确认","type":"workflow","confidence":0.74,"reason":"涉及合同主体与用工制度，建议在发布前加入法务确认节点。","priority":"medium"}],"recommendedFlow":[{"id":"flow-1","title":"Planner 拆解任务","agent":"planner","description":"抽取合同审查、条款分类、修改建议、文书生成四个子任务。","status":"active","icon":"agent"},{"id":"flow-2","title":"Executor 调用 Dify 审查链","agent":"executor","description":"结合上传文件与规则提示词，输出结构化风险列表。","status":"ready","icon":"spark"},{"id":"flow-3","title":"Validator 校验结论","agent":"validator","description":"检查条款引用、风险解释和修改建议是否一致。","status":"pending","icon":"shield"},{"id":"flow-4","title":"n8n 分发结果与通知","agent":"executor","description":"将结果同步到任务详情、邮件通知或签约流程入口。","status":"pending","icon":"workflow"}],"templates":[{"id":"tpl-contract-sign","title":"合同生成 -> 风险审查 -> 发起签署","summary":"适合劳动合同、采购合同和保密协议的标准化法务链路。","type":"contract","href":"/workflows"},{"id":"tpl-dev-ci","title":"需求分析 -> 代码草案 -> CI 检查","summary":"适合研发团队快速生成接口、测试清单和持续集成建议。","type":"dev","href":"/workflows"},{"id":"tpl-content-publish","title":"内容生成 -> 合规审查 -> 发布通知","summary"