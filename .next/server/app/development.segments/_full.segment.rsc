7:["$","$L10",null,{"data":{"hero":{"title":"把业务需求压缩成代码草案、测试清单和发布建议。","description":"围绕一份业务需求，快速整理接口设计、代码草案、测试重点和交付建议，减少需求到实现之间的反复确认。"},"requirementInput":"为 CRM 系统新增客户线索同步模块：支持从 Excel 导入线索，校验手机号和邮箱格式，去重后写入 PostgreSQL，并提供查询、重试和失败记录导出接口。","presets":["根据这个需求生成 FastAPI 接口和测试建议","把 PRD 拆成前端页面结构和 API 设计","为 Excel 导入模块生成校验逻辑与失败重试方案","给这个服务补一套 CI 流水线与回归测试清单"],"stackOptions":[{"id":"next-fastapi","label":"Next.js + FastAPI","description":"适合当前项目栈，保留 App Router 和 Python 服务聚合方式。","tags":["Next.js","TypeScript","FastAPI"]},{"id":"react-node","label":"React + Node.js","description":"适合前后端都走 TS 的快速交付场景。","tags":["React","Express","Prisma"]},{"id":"vue-go","label":"Vue + Go","description":"适合高吞吐接口场景的另一套实现思路。","tags":["Vue","Go","REST"]},{"id":"python-automation","label":"Python Automation","description":"强调任务执行、批处理和调度脚本的工程方案。","tags":["Python","Celery","Redis"]}],"defaultStack":"next-fastapi","integrations":[{"id":"int-git","name":"Git 仓库","status":"ready","description":"用于承接代码草案、提交记录和 PR 协作。"},{"id":"int-jenkins","name":"Jenkins","status":"planned","description":"用于串联构建、测试和发布结果回传。"},{"id":"int-docker","name":"Docker Registry","status":"planned","description":"用于记录镜像构建、版本管理和发布历史。"},{"id":"int-issues","name":"需求工单系统","status":"blocked","description":"当前需求来源还未统一，待对接飞书或 Jira。"}],"stateSnapshots":{"default":{"title":"待生成","summary":"当前展示需求输入与技术栈选择，尚未生成代码结果。","status":"draft","notice":"默认状态下建议先确认技术栈、异常处理策略和导入规模。","noticeTone":"neutral","actionLabel":"生成方案","codeArtifacts":[],"apiSuggestions":[],"testSuggestions":[{"id":"default-test-1","title":"先定义导入成功 / 失败口径","level":"important","description":"在真正生成测试前，先统一导入条数、去重规则和失败重试的业务口径。"}],"pipelineSuggestions":[{"id":"default-pipeline-1","stage":"Plan","tool":"Manual","description":"当前阶段先由前端 mock 页面承接，后续再接真实仓库和 CI 系统。"}]},"loading":{"title":"生成中","summary":"正在拆解需求、生成接口定义并构造测试建议。","status":"running","notice":"系统正在拆解需求边界并生成接口草案，结果会分段返回。","noticeTone":"warning","actionLabel":"生成中...","codeArtifacts":[],"apiSuggestions":[],"testSuggestions":[{"id":"loading-test-1","title":"等待生成结果","level":"nice","description":"测试建议将在代码骨架生成后联动展示，避免需求和实现脱节。"}],"pipelineSuggestions":[{"id":"loading-pipeline-1","stage":"Generate","tool":"Dify","description":"正在调用生成链以输出接口草案、测试点和 CI 建议。"}]},"success":{"title":"生成完成","summary":"已生成 FastAPI 接口草案、导入任务服务和查询接口建议。","status":"completed","notice":"建议下一步把代码草案推送到 Git 仓库，并在任务详情页记录生成留痕。","noticeTone":"success","actionLabel":"推送到仓库","codeArtifacts":[{"id":"artifact-api","title":"接口路由草案","filename":"app/api/leads/routes.py","language":"python","summary":"提供导入、查询失败记录和重试接口。","content":"from fastapi import APIRouter, UploadFile\n\nrouter = APIRouter(prefix=\"/leads\", tags=[\"leads\"])\n\n@router.post(\"/import\")\nasync def import_leads(file: UploadFile):\n    return {\"job_id\": \"lead-import-001\", \"status\": \"queued\"}\n\n@router.get(\"/imports/{job_id}\")\nasync def get_import_job(job_id: str):\n    return {\"job_id\": job_id, \"status\": \"running\"}\n\n@router.post(\"/imports/{job_id}/retry\")\nasync def retry_failed_rows(job_id: str):\n    return {\"job_id\": job_id, \"status\": \"queued\"}\n"},{"id":"artifact-service","title":"导入服务草案","filename":"app/services/lead_import_service.py","language":"python","summary":"处理 Excel 解析、字段校验和去重入库。","content":"class LeadImportService:\n    async def validate_rows(self, rows: list[dict]) -> list[dict]:\n        validated = []\n        for row in rows:\n            if not row.get(\"mobile\") or not row.get(\"email\"):\n                continue\n            validated.append(row)\n        return validated\n\n    async def persist_rows(self, rows: list[dict]) -> int:\n        return len(rows)\n"}],"apiSuggestions":[{"id":"api-1","method":"POST","path":"/api/dev/leads/import","summary":"上传 Excel 并创建异步导入任务。","payload":["file","source","dedupeStrategy"]},{"id":"api-2","method":"GET","path":"/api/dev/leads/imports/{jobId}","summary":"查询导入任务状态、失败条数和处理进度。","payload":["jobId"]},{"id":"api-3","method":"POST","path":"/api/dev/leads/imports/{jobId}/retry","summary":"按任务维度重试失败记录。","payload":["jobId","failedRowIds"]}],"testSuggestions":[{"id":"test-1","title":"文件结构校验","level":"critical","description":"验证空文件、错误表头、超大文件和非法扩展名时的处理结果。"},{"id":"test-2","title":"字段去重与幂等","level":"critical","description":"确保手机号 + 邮箱组合去重策略稳定，重复提交不会产生脏数据。"},{"id":"test-3","title":"失败重试链路","level":"important","description":"验证失败记录导出、重试后状态回写以及部分成功场景。"}],"pipelineSuggestions":[{"id":"pipeline-1","stage":"Lint","tool":"ESLint + Ruff","description":"前端和 FastAPI 服务分别做静态检查，避免生成代码直接进入仓库。"},{"id":"pipeline-2","stage":"Test","tool":"Pytest + Playwright","description":"接口层走 Pytest，前端上传和结果展示走关键路径 E2E。"},{"id":"pipeline-3","stage":"Build","tool":"Docker + Jenkins","description":"构建前后端镜像，预留 Jenkins 或 GitHub Actions 的执行占位。"}]},"empty":{"title":"没有生成结果","summary":"当前筛选条件或输入内容不足，暂时没有推荐代码方案。","status":"completed","notice":"空结果适合演示需求描述过短或上下文不完整时的反馈。","noticeTone":"neutral","actionLabel":"补充需求","codeArtifacts":[],"apiSuggestions":[],"testSuggestions":[{"id":"empty-test-1","title":"先补充边界条件","level":"important","description":"建议明确导入规模、失败处理和权限模型，再触发生成。"}],"pipelineSuggestions":[]},"error":{"title":"生成失败","summary":"模拟底层生成链超时，页面保留需求描述与技术栈选择。","status":"failed","notice":"FastAPI 聚合层或 Dify 生成链返回异常。建议返回 traceId 并支持重试。","noticeTone":"danger","actionLabel":"重试生成","codeArtifacts":[],"apiSuggestions":[],"testSuggestions":[{"id":"error-test-1","title":"异常兜底","level":"critical","description":"保留用户输入，允许复制需求、重试生成或切换简化模式。"}],"pipelineSuggestions":[{"id":"error-pipeline-1","stage":"Observe","tool":"Logs","description":"后续需要记录 prompt、链路耗时和失败节点，方便定位问题。"}]}},"integrationPoints":["POST /api/dev/generate","POST /api/dev/test-plan","GET /api/dev/integrations","POST /api/dev/push-repo"]}}]
