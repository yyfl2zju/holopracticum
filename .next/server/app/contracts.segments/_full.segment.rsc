7:["$","$L10",null,{"data":{"hero":{"title":"让合同审查像一个可追踪的工作流，而不是一次黑盒输出。","description":"从上传合同、识别条款到输出风险建议和修订版本，整个过程都保留清晰的处理路径和结果留痕。"},"contractTypes":[{"id":"labor","label":"劳动合同","description":"适合用工、试用期、竞业限制和保密条款审查。"},{"id":"procurement","label":"采购合同","description":"聚焦交付、验收、违约责任和付款节点。"},{"id":"nda","label":"保密协议","description":"检查保密边界、例外条款和违约赔偿约束。"},{"id":"service","label":"服务合同","description":"适合服务范围、里程碑、发票与终止机制审查。"},{"id":"custom","label":"自定义文档","description":"交由 Dify 文档理解链识别后进入人工确认模式。"}],"defaultType":"labor","uploads":[{"id":"contract-file-001","name":"劳动合同-签署版-v7.pdf","size":"2.1 MB","kind":"contract","status":"parsed"},{"id":"contract-file-002","name":"员工手册-试用期政策.docx","size":"612 KB","kind":"requirements","status":"parsed"}],"templates":[{"id":"tpl-labor-revise","title":"创业公司劳动合同修订版","description":"聚焦试用期、竞业限制和赔偿责任的简洁版模板。","category":"劳动用工","href":"/contracts"},{"id":"tpl-nda-fast","title":"轻量保密协议","description":"适合合作前快速签署，条款简洁，便于后续扩展。","category":"保密协议","href":"/contracts"},{"id":"tpl-service-milestone","title":"服务合同里程碑版","description":"适合自由职业和项目制合作，强调交付节点与付款条件。","category":"服务合同","href":"/contracts"}],"cases":[{"id":"case-001","title":"试用期薪资与转正条件表述不清","summary":"建议把试用期工资、考核标准和转正评估节点拆分成独立条款。","riskLevel":"high","source":"平台知识案例库 / 用工纠纷专题"},{"id":"case-002","title":"竞业限制条款范围过宽","summary":"限制范围覆盖全部关联业务，建议收敛到核心岗位和核心业务线。","riskLevel":"medium","source":"平台知识案例库 / 竞业限制专题"},{"id":"case-003","title":"违约赔偿缺少上限","summary":"建议增加违约责任上限和损失计算口径，避免后续争议扩大。","riskLevel":"medium","source":"平台知识案例库 / 合同违约专题"}],"exportOptions":[{"id":"export-report","label":"导出审查报告","description":"输出 PDF 风险报告，适合归档和汇报。"},{"id":"export-docx","label":"导出修订版 DOCX","description":"生成可继续修改的条款文档。"},{"id":"export-workflow","label":"推送至签约流程","description":"将结果交给 n8n 工作流或电子签服务入口。"}],"stateSnapshots":{"default":{"title":"待审查","summary":"已上传合同和补充制度文件，等待发起审查。","status":"draft","notice":"当前为默认状态。点击状态预演可查看加载、成功、空结果和错误反馈。","noticeTone":"neutral","riskCountLabel":"尚未生成风险结果","risks":[],"suggestions":["建议补充岗位说明书或员工手册，以提高风险判断准确度。","建议在提交前确认签约主体和适用用工制度版本。"]},"loading":{"title":"审查中","summary":"正在抽取条款、匹配风险规则并生成修改建议。","status":"running","notice":"系统正在抽取合同条款并匹配风险规则，完成后会自动生成修订建议。","noticeTone":"warning","riskCountLabel":"正在分析 28 项风险规则","risks":[],"suggestions":["等待条款抽取完成后，将生成结构化风险列表。","后续可加入 OCR、知识库引用和相似案例匹配。"]},"success":{"title":"审查完成","summary":"已识别高风险 2 项、中风险 2 项，并生成对应修改建议。","status":"completed","notice":"建议下一步导出修订版合同，或推送到任务详情页查看完整执行留痕。","noticeTone":"success","riskCountLabel":"共识别 4 项主要风险","risks":[{"id":"risk-001","level":"high","clause":"第 4 条 试用期约定","issue":"试用期工资比例和转正判定条件表述不清，存在用工争议风险。","suggestion":"拆分工资、转正评估标准和试用期时长，并补充评估节点。"},{"id":"risk-002","level":"high","clause":"第 9 条 违约责任","issue":"违约赔偿未设置合理上限，可能导致责任范围过宽。","suggestion":"增加违约责任上限和损失计算口径，限定至直接损失。"},{"id":"risk-003","level":"medium","clause":"第 7 条 竞业限制","issue":"竞业限制对象和业务范围界定过宽，缺少地域边界。","suggestion":"收敛到核心岗位、核心业务与合理期限，并明确补偿标准。"},{"id":"risk-004","level":"medium","clause":"第 11 条 合同解除","issue":"解除条件与通知期说明不足，可能影响执行一致性。","suggestion":"补充单方解除前提、通知期和争议解决顺序。"}],"suggestions":["优先处理试用期和违约责任条款，这两项对用工争议影响最大。","若后续需要签署，建议加入人工确认节点，避免模板直接流转。","修订后可生成创业公司适配版合同模板，供后续复用。"]},"empty":{"title":"未识别到明显风险","summary":"当前筛选条件或规则集下没有匹配到高优先级问题。","status":"completed","notice":"空结果不代表合同无风险，只表示当前规则集没有命中重点告警。","noticeTone":"neutral","riskCountLabel":"当前筛选下无结果","risks":[],"suggestions":["可切换合同类型或扩大规则范围重新审查。","也可以上传补充资料，例如附件、付款条款说明或制度文本。"]},"error":{"title":"审查失败","summary":"审查链路执行异常，上传文件和当前合同类型已保留。","status":"failed","notice":"Dify 文档处理链返回超时。建议记录 traceId 并允许用户稍后重试。","noticeTone":"danger","riskCountLabel":"本次结果不可用","risks":[],"suggestions":["保留用户输入和上传文件，不要强制重新上传。","提供重试入口和错误排查建议，例如文件损坏或文本层缺失。"]}},"integrationPoints":["POST /api/contracts/review","GET /api/contracts/templates","GET /api/contracts/cases","POST /api/contracts/export"]}}]
