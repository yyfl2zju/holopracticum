0:{"buildId":"DFjJdhjNkjHQmU3-FbIwc","rsc":["$","$1","c",{"children":[["$","$L2",null,{"data":{"hero":{"title":"把一个主题拆成标题、正文、平台改写和合规检查。","description":"围绕一个主题统一完成正文、平台改写、提示词和合规检查，适合市场和运营团队快速产出首版内容。"},"topicInput":"为“AI Agent 平台帮助小微企业提升效率”生成一组官网介绍文案，同时给出公众号和小红书版本，并做一次合规检查。","presets":["写一篇面向创业者的 AI 办公产品介绍文案","围绕新品发布活动生成官网、公众号和小红书三套内容","根据这个主题生成标题、正文和海报提示词","帮我重写一篇更适合企业客户决策者阅读的介绍文案"],"styleOptions":[{"id":"professional","label":"专业克制","description":"适合官网、B 端产品页和提案材料。"},{"id":"warm","label":"亲和沟通","description":"适合公众号、私域触达和品牌陪伴式内容。"},{"id":"direct","label":"结果导向","description":"适合短文案、广告文案和卖点提炼。"},{"id":"launch","label":"发布感","description":"适合新品发布、活动预热和产品上线公告。"}],"defaultStyle":"professional","platformOptions":[{"id":"website","label":"官网","description":"适合结构化介绍、卖点分层和功能表达。"},{"id":"wechat","label":"公众号","description":"适合故事化叙述和场景解释。"},{"id":"xiaohongshu","label":"小红书","description":"适合更轻、更口语化的经验分享表达。"},{"id":"douyin","label":"抖音脚本","description":"适合短句节奏、镜头提示和行动召唤。"},{"id":"linkedin","label":"LinkedIn","description":"适合面向专业决策者的国际化表述。"}],"defaultPlatforms":["website","wechat","xiaohongshu"],"stateSnapshots":{"default":{"title":"待生成","summary":"当前已输入主题并完成风格、平台选择，尚未生成内容。","status":"draft","notice":"默认状态适合先确认语气、平台和禁用词边界，再触发生成。","noticeTone":"neutral","actionLabel":"生成内容","generatedTitles":[],"copyBlocks":[],"rewrites":[],"posterPrompts":[],"complianceIssues":[]},"loading":{"title":"生成中","summary":"正在生成标题、正文、多平台改写和合规分析。","status":"running","notice":"系统正在生成内容并同步做风险扫描，通常会先返回标题和正文，再补充平台改写。","noticeTone":"warning","actionLabel":"生成中...","generatedTitles":[],"copyBlocks":[],"rewrites":[],"posterPrompts":[],"complianceIssues":[]},"success":{"title":"内容已生成","summary":"已生成 3 个标题方案、1 份主文案、3 个平台改写和 2 条海报提示词。","status":"completed","notice":"建议下一步将最终版本推送到工作流页，接入审批、发布或素材制作流程。","noticeTone":"success","actionLabel":"推送到工作流","generatedTitles":[{"id":"title-1","title":"让小团队也能拥有可落地的 AI Agent 工作台","tone":"专业克制"},{"id":"title-2","title":"从文档到流程，一套 AI 平台把小微企业的重复工作接住","tone":"结果导向"},{"id":"title-3","title":"不是多一个工具，而是多一条能跑起来的业务链路","tone":"发布感"}],"copyBlocks":[{"id":"copy-1","heading":"官网主文案","summary":"面向官网首屏与产品概览区的核心表达。","content":"HoloPracticum 是一个面向小微企业、创业者和自由职业者的 AI Agent 工作平台。它不是简单地把模型能力堆在一起，而是把合同处理、开发辅助、内容创作、数据分析和流程编排收拢进同一个工作台，让任务可以被识别、分发、执行和复查。对用户来说，输入一句需求、上传一份文件，就能看到一条清晰的任务链开始运转；对团队来说，这意味着更低的协作摩擦、更透明的执行过程，以及更适合持续迭代的业务接口。"}],"rewrites":[{"id":"rewrite-1","platform":"website","title":"官网版本","description":"偏结构化、强调平台能力和可落地性。","content":"一个统一的 AI Agent 平台，帮助小微企业用自然语言和可视化流程完成合同处理、开发协作、内容生成与经营分析。"},{"id":"rewrite-2","platform":"wechat","title":"公众号版本","description":"偏故事化，适合介绍应用场景和实际收益。","content":"很多小团队不是没有工具，而是工具太多、流程太散。HoloPracticum 想解决的，是把这些散落的动作串成一条真正能跑起来的 AI 工作流。"},{"id":"rewrite-3","platform":"xiaohongshu","title":"小红书版本","description":"偏口语化，突出效率和真实使用感受。","content":"如果你是小团队创业者，真的会很需要这种能把合同、写文案、做流程都放一起的 AI 工作台，省掉来回切工具的时间。"}],"posterPrompts":[{"id":"poster-1","title":"产品海报主视觉","prompt":"现代 SaaS 工作台，清晰的信息层级，浅色办公背景，数据卡片与流程节点轻微悬浮，突出 AI Agent 协作感，商务、克制、专业"},{"id":"poster-2","title":"活动宣传配图","prompt":"小微企业数字化办公场景，桌面屏幕展示任务流与 Agent 卡片，明亮配色，简洁 B 端视觉，适合产品宣发"}],"complianceIssues":[{"id":"comp-1","level":"medium","title":"效率提升描述偏泛","detail":"“提升效率”表述较宽，缺少具体范围和场景边界。","suggestion":"建议补充适用场景，例如“减少多工具切换和重复整理成本”。"},{"id":"comp-2","level":"low","title":"能力表述可再收敛","detail":"内容里涵盖较多模块，首屏表达可能略显饱和。","suggestion":"建议首屏聚焦 2 到 3 个核心场景，其余放在下方能力卡展开。"}]},"empty":{"title":"暂无可用结果","summary":"当前主题过于简短或筛选条件不足，暂时没有生成推荐内容。","status":"completed","notice":"空状态适合演示首次使用或内容意图不明确时的页面反馈。","noticeTone":"neutral","actionLabel":"补充主题","generatedTitles":[],"copyBlocks":[],"rewrites":[],"posterPrompts":[],"complianceIssues":[]},"error":{"title":"生成失败","summary":"模拟内容生成链或合规接口异常，页面保留主题与平台设置。","status":"failed","notice":"内容生成服务返回超时。建议保留输入、支持重试，并记录 traceId。","noticeTone":"danger","actionLabel":"重试生成","generatedTitles":[],"copyBlocks":[],"rewrites":[],"posterPrompts":[],"complianceIssues":[{"id":"comp-error-1","level":"high","title":"无法完成合规检查","detail":"当前结果不可用，无法确认是否存在敏感表述或夸大承诺。","suggestion":"重试生成前，请先保留草稿并避免直接发布。"}]}},"integrationPoints":["POST /api/content/generate","POST /api/content/rewrite","POST /api/content/compliance-check","POST /api/content/export"]}}],["$L3"],"$L4"]}],"loading":null,"isPartial":false}
